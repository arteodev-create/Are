{
  "name": "veritas",
  "private": true,
  "version": "1.0.0",
  "description": "Realtime messaging app with channels, communities, profiles, AI assistants, and Cloudinary storage.",
  "author": "Veritas",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server/index.js",
    "dev": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "icons": "node scripts/generate-icons.mjs",
    "build": "vite build",
    "build:pages": "vite build --base=/",
    "smoke": "node scripts/smoke.mjs",
    "smoke:join-policy": "node scripts/join-policy-smoke.mjs",
    "smoke:ai": "node scripts/ai-model-smoke.mjs",
    "desktop:dev": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --win --x64",
    "mobile:sync": "npm run build && cap sync android",
    "mobile:apk": "npm run mobile:sync && cd mobile/android && gradlew.bat assembleDebug",
    "preview": "vite preview --host 0.0.0.0",
    "pwa:build": "vite build",
    "pwa:preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "build": {
    "appId": "app.veritas.desktop",
    "productName": "Veritas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName} Setup 1.0.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "cloudinary": "^2.10.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5"
  }
}
